# Copy to .env (local) or set as Vercel project environment variables.
# These are SECRETS — never commit real values or put them in the app.

# Instagram (Meta Instagram API with Instagram Login)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# Facebook Login
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Google (Google Cloud OAuth client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: lock CORS to your app origin (defaults to "*").
# For a Capacitor iOS build this is typically capacitor://localhost
# ALLOWED_ORIGIN=capacitor://localhost
